{
  "name": "@smartshop/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "test": "echo \"api: no tests yet\""
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@smartshop/types": "workspace:*",
    "@smartshop/utils": "workspace:*",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.9",
    "eslint": "^9.22.0",
    "prisma": "^7.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
