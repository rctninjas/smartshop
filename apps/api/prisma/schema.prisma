generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id               String                    @id @default(cuid())
  name             String
  slug             String                    @unique
  parentId         String?
  parent           Category?                 @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children         Category[]                @relation("CategoryHierarchy")
  products         Product[]
  attributeSchemas CategoryAttributeSchema[]
  isActive         Boolean                   @default(true)
  sortOrder        Int                       @default(0)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deletedAt        DateTime?
}

model Product {
  id            String        @id @default(cuid())
  title         String
  itemNumber    String        @default("") @db.VarChar(100) @map("article")
  slug          String        @unique
  description   String
  price         Int
  sale          Int?
  currency      String        @default("RUB")
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  schemaVersion Int?
  attributesSnapshot Json?
  isPublished   Boolean       @default(false)
  publishedAt   DateTime?
  publishedBy   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  variants      ProductVariant[]
  images        ProductImage[]
  orderItems    OrderItem[]

  @@index([categoryId])
  @@index([isPublished])
  @@index([price])
}

model CategoryAttributeSchema {
  id           String   @id @default(cuid())
  subcategoryId String
  subcategory  Category @relation(fields: [subcategoryId], references: [id])
  version      Int
  status       String
  fieldsJson   Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([subcategoryId, version])
  @@index([subcategoryId, status])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  sku         String   @unique
  color       String
  size        String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  originalUrl String?
  smUrl     String?
  mediumUrl String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Order {
  id          String        @id @default(cuid())
  status      String
  customerName String
  customerPhone String
  customerEmail String
  deliveryMethod String
  deliveryAddress String
  trackNumber String?
  paymentMethod String
  isPaid      Boolean       @default(false)
  amountTotal Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       OrderItem[]
  history     OrderStatusHistory[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                 String   @id @default(cuid())
  orderId            String
  order              Order    @relation(fields: [orderId], references: [id])
  productId          String?
  product            Product? @relation(fields: [productId], references: [id])
  quantity           Int
  titleSnapshot      String
  priceSnapshot      Int
  attributesSnapshot Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([orderId])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  fromStatus String?
  toStatus  String
  reason    String?
  changedBy String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}
